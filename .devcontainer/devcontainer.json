{
  "name": "claims-intelligence-platform",
  "dockerComposeFile": "compose.yml",
  "service": "workspace",
  "workspaceFolder": "/home/vscode/workspaces/claims-intelligence-platform",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "username": "vscode"
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "25",
      "jdkDistro": "tem",
      "installMaven": true,
      "mavenVersion": "latest"
    },
    "ghcr.io/devcontainers/features/go:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },
  "forwardPorts": [
    5173
  ],
  "remoteUser": "vscode",
  "postCreateCommand": "mkdir -p ~/.ssh && ssh-keyscan github.com >> ~/.ssh/known_hosts && git config --global gpg.format ssh && git config --global gpg.ssh.program /usr/bin/ssh-keygen && git config --global commit.gpgsign true",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot-dashboard",
        "golang.go",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker"
      ]
    },
    "jetbrains": {
      "backend": "IntelliJ"
    }
  }
}